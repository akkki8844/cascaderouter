# Copy to .env for LOCAL TESTING ONLY and fill in. NEVER commit the real .env,
# and NEVER bake it into the image — the judging harness injects all three of
# these at runtime and the submitted container must read them from the
# environment (Participant Guide, Track 1).
FIREWORKS_API_KEY=fw_your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Comma-separated permitted model ids. The ids below are the launch-day set
# observed on the Fireworks model library / other Track 1 submissions — the
# harness-injected value always wins over anything written here.
ALLOWED_MODELS=accounts/fireworks/models/gemma-4-31b-it,accounts/fireworks/models/kimi-k2p7-code,accounts/fireworks/models/minimax-m3
